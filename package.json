{
  "name": "setuplens",
  "version": "0.2.0-alpha.4",
  "description": "Diagnose why unfamiliar repositories fail to install, configure, or start.",
  "type": "module",
  "bin": {
    "setuplens": "./bin/setuplens.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node ./bin/setuplens.js",
    "test": "node --test",
    "check": "node ./scripts/check-syntax.js",
    "corpus": "node ./scripts/evaluate-failure-corpus.js",
    "dataset:collect": "node ./bin/setuplens.js failure-dataset collect",
    "dataset:review": "node ./bin/setuplens.js failure-dataset review",
    "dataset:history": "node ./bin/setuplens.js failure-dataset review --history .setuplens/failure-dataset/scorecard-history.json",
    "dataset:promote": "node ./bin/setuplens.js failure-dataset promote",
    "dataset:clean": "node ./bin/setuplens.js failure-dataset clean",
    "corpus:promote-public": "node ./scripts/promote-public-scan-patterns.js",
    "report:capability": "node ./scripts/generate-capability-report.js",
    "demo": "node ./bin/setuplens.js scan . --format html --output ./docs/demo-report.html"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "environment",
    "repository",
    "diagnostics",
    "onboarding",
    "devops",
    "security"
  ],
  "author": "Milankunderzzz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Milankunderzzz/SetupLens.git"
  },
  "bugs": {
    "url": "https://github.com/Milankunderzzz/SetupLens/issues"
  },
  "homepage": "https://github.com/Milankunderzzz/SetupLens#readme",
  "devDependencies": {
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0"
  }
}
